\section{Page 5: Experimental Insights and Performance}
\textbf{Exact disclaimer (must remain unchanged):} \\
Classifier and regression results are exploratory and useful for demo discussion, but not final predictive proof. Methodology tightening is still pending.

\begin{figure}[H]
\centering
\includegraphics[width=0.92\textwidth]{06_classifier_metrics.png}
\caption{Exploratory classifier metrics used for discussion, not release-safe proof.}
\label{fig:clfmetrics}
\end{figure}

\begin{figure}[H]
\centering
\includegraphics[width=0.92\textwidth]{07_regression_metrics.png}
\caption{Exploratory regression metrics used to assess predictive direction under current feature design.}
\label{fig:regmetrics}
\end{figure}

\begin{figure}[H]
\centering
\includegraphics[width=0.92\textwidth]{14_classifier_feature_importance.png}
